generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String          @id @default(uuid())
  email        String          @unique
  passwordHash String
  createdAt    DateTime        @default(now())
  weeks        Week[]
  logs         StudyLog[]
  scores       PracticeScore[]
}

model Week {
  id         Int      @id @default(autoincrement())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekNumber Int
  title      String
  days       Int      @default(7)
  isOpen     Boolean  @default(false)
  createdAt  DateTime @default(now())
  topics     Topic[]
  note       Note?

  @@unique([userId, weekNumber])
}

model Topic {
  id        Int      @id @default(autoincrement())
  weekId    Int
  week      Week     @relation(fields: [weekId], references: [id], onDelete: Cascade)
  text      String
  tag       String
  isChecked Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Note {
  id        Int      @id @default(autoincrement())
  weekId    Int      @unique
  week      Week     @relation(fields: [weekId], references: [id], onDelete: Cascade)
  content   String   @default("")
  updatedAt DateTime @updatedAt
}

model StudyLog {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  duration  String?
  createdAt DateTime @default(now())
}

model PracticeScore {
  id           Int       @id @default(autoincrement())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  examName     String
  score        Float?
  passingScore Float     @default(72)
  takenAt      DateTime?
}
